<?xml version="1.0"?>
<!DOCTYPE module PUBLIC "-//Checkstyle//DTD Checkstyle Configuration 1.3//EN" "https://checkstyle.org/dtds/configuration_1_3.dtd">
<module name="Checker">
    <property name="charset" value="UTF-8"/>
    <property name="severity" value="error"/>

    <module name="TreeWalker">
        <!-- Sprawdzanie nieużywanych importów -->
        <module name="UnusedImports"/>
        
        <!-- Sprawdzanie nazewnictwa metod -->
        <module name="MethodName"/>

        <!-- Zakaz używania System.out.println oraz System.err.println -->
        <module name="RegexpSinglelineJava">
            <property name="format" value="System\.(out|err)\.print"/>
            <property name="ignoreComments" value="true"/>
            <property name="message" value="Use a logger (Slf4j) instead of System.out/err."/>
        </module>

        <!-- Zakaz używania e.printStackTrace() -->
        <module name="RegexpSinglelineJava">
            <property name="format" value="\.printStackTrace\(\)"/>
            <property name="ignoreComments" value="true"/>
            <property name="message" value="Use a logger to log exceptions instead of printStackTrace()."/>
        </module>
    </module>
</module>
